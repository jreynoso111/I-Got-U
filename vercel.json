{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.buddybalance.net"
        }
      ],
      "destination": "https://buddybalance.net/:path*",
      "permanent": true
    }
  ]
}
